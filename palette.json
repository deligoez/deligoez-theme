{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "Deligoez Theme Palette",
  "description": "Single source of truth for all Deligoez theme variants",
  "light": {
    "editor": {
      "background": "#ffffff",
      "foreground": "#333333",
      "selection": "#d2e3fe",
      "lineHighlight": "none",
      "lineNumber": "#a7a7a7",
      "gutter": "#ffffff"
    },
    "syntax": {
      "keyword":       { "color": "#ce5391", "style": "italic",      "note": "class, function, return, if, new, use, namespace" },
      "string":        { "color": "#ba0011", "style": "normal",      "note": "string literals" },
      "number":        { "color": "#009999", "style": "normal",      "note": "numeric literals" },
      "comment":       { "color": "#56606b", "style": "italic",      "note": "line and block comments" },
      "commentDoc":    { "color": "#999988", "style": "italic",      "note": "doc comments (/** */)" },
      "commentDocTag": { "color": "#8c97a1", "style": "bold-italic", "note": "@param, @return, @throws" },
      "function":      { "color": "#157dae", "style": "normal",      "note": "function/method names" },
      "class":         { "color": "#035d86", "style": "normal",      "note": "class names, types, constructors" },
      "interface":     { "color": "#795da3", "style": "normal",      "note": "interfaces, enums, attributes" },
      "instanceMethod":{ "color": "#4c919a", "style": "normal",      "note": "instance method calls" },
      "property":      { "color": "#035d86", "style": "normal",      "note": "instance fields, properties" },
      "constant":      { "color": "#2ba6c4", "style": "normal",      "note": "constants, static finals" },
      "variable":      { "color": "#333333", "style": "normal",      "note": "variables ($var)" },
      "variableSpecial":{ "color": "#3d227f", "style": "normal",     "note": "$this, self, static" },
      "parameter":     { "color": "#000000", "style": "normal",      "note": "function parameters" },
      "operator":      { "color": "#a71d5d", "style": "bold",        "note": "=, +, -, =>, ->, ::" },
      "tag":           { "color": "#63a35c", "style": "normal",      "note": "HTML/XML tag names, YAML keys" },
      "attribute":     { "color": "#795da3", "style": "normal",      "note": "HTML attributes, PHP attributes" },
      "attributeValue":{ "color": "#183691", "style": "normal",      "note": "HTML attribute values, string escapes" },
      "phpTag":        { "color": "#c35386", "style": "normal",      "note": "<?php, ?>" },
      "predefined":    { "color": "#0086b3", "style": "normal",      "note": "predefined symbols, built-ins" },
      "link":          { "color": "#0000ff", "style": "italic",      "note": "hyperlinks" },
      "regex":         { "color": "#009926", "style": "normal",      "note": "regular expressions" },
      "stringSpecial": { "color": "#dd1144", "style": "normal",      "note": "heredoc, exec commands" },
      "symbol":        { "color": "#660e7a", "style": "italic",      "note": "constants, static fields (DEFAULT_CONSTANT)" }
    },
    "ui": {
      "selection":       "#d2e3fe",
      "matchedBrace":    "#99ccbb",
      "searchResult":    "#ffff00",
      "identifierUnderCaret": "#eaeeee",
      "foldedText":      "#69747e",
      "todo":            "#0000ff",
      "breakpoint":      "#ffc8c8"
    },
    "diff": {
      "inserted": "#c8f2c8",
      "deleted":  "#d6d6d6",
      "modified": "#cad9fa"
    },
    "terminal": {
      "foreground":  "#333333",
      "background":  "#ffffff",
      "black":       "#000000",
      "red":         "#ba0011",
      "green":       "#63a35c",
      "yellow":      "#c18401",
      "blue":        "#183691",
      "magenta":     "#ce5391",
      "cyan":        "#2ba6c4",
      "white":       "#cccccc",
      "brightBlack": "#666666",
      "brightRed":   "#ff0000",
      "brightGreen": "#66c358",
      "brightYellow":"#cdcd00",
      "brightBlue":  "#74abe0",
      "brightMagenta":"#c35386",
      "brightCyan":  "#4c919a",
      "brightWhite": "#ffffff"
    }
  },
  "dark": {
    "_note": "Generated from light palette using OKLCH perceptual lightness inversion",
    "_method": "L_new = 1.0 - L_old + offset, Chroma reduced 25%, Hue preserved",
    "editor": {
      "background": "#1a1a1f",
      "foreground": "#d4d4d8",
      "selection": "#3a4a6a",
      "lineHighlight": "none",
      "lineNumber": "#55555d",
      "gutter": "#1a1a1f"
    },
    "syntax": {
      "keyword":       { "color": "#ffa1cd", "style": "italic" },
      "string":        { "color": "#ffa396", "style": "normal" },
      "number":        { "color": "#83d4d3", "style": "normal" },
      "comment":       { "color": "#6b7580", "style": "italic" },
      "commentDoc":    { "color": "#7a7d72", "style": "italic" },
      "commentDocTag": { "color": "#7a8590", "style": "bold-italic" },
      "function":      { "color": "#7ab9e0", "style": "normal" },
      "class":         { "color": "#92c7e9", "style": "normal" },
      "interface":     { "color": "#b29ed6", "style": "normal" },
      "instanceMethod":{ "color": "#9bcdd4", "style": "normal" },
      "property":      { "color": "#92c7e9", "style": "normal" },
      "constant":      { "color": "#75c2d9", "style": "normal" },
      "variable":      { "color": "#d4d4d8", "style": "normal" },
      "variableSpecial":{ "color": "#9d92de", "style": "normal" },
      "parameter":     { "color": "#d4d4d8", "style": "normal" },
      "operator":      { "color": "#ffa3c7", "style": "bold" },
      "tag":           { "color": "#8ebe89", "style": "normal" },
      "attribute":     { "color": "#b29ed6", "style": "normal" },
      "attributeValue":{ "color": "#83a4ef", "style": "normal" },
      "phpTag":        { "color": "#f89ec2", "style": "normal" },
      "predefined":    { "color": "#75c2d9", "style": "normal" },
      "link":          { "color": "#6eb4ff", "style": "italic" },
      "regex":         { "color": "#7ed381", "style": "normal" },
      "stringSpecial": { "color": "#ff848d", "style": "normal" },
      "symbol":        { "color": "#ca8ddb", "style": "italic" }
    },
    "ui": {
      "selection":       "#3a4a6a",
      "matchedBrace":    "#3a5548",
      "searchResult":    "#ffa1cd44",
      "identifierUnderCaret": "#ffffff0d",
      "foldedText":      "#55555d",
      "todo":            "#6eb4ff",
      "breakpoint":      "#4a1a1a"
    },
    "diff": {
      "inserted": "#1a3a1a",
      "deleted":  "#3a1a1a",
      "modified": "#1a2a4a"
    },
    "terminal": {
      "foreground":  "#d4d4d8",
      "background":  "#1a1a1f",
      "black":       "#1a1a1f",
      "red":         "#ffa396",
      "green":       "#8ebe89",
      "yellow":      "#d6a862",
      "blue":        "#83a4ef",
      "magenta":     "#ffa1cd",
      "cyan":        "#75c2d9",
      "white":       "#cccccc",
      "brightBlack": "#666666",
      "brightRed":   "#ff8e7a",
      "brightGreen": "#9ade8f",
      "brightYellow":"#d3d566",
      "brightBlue":  "#a1caf3",
      "brightMagenta":"#f89ec2",
      "brightCyan":  "#9bcdd4",
      "brightWhite": "#e8e8e8"
    }
  }
}
